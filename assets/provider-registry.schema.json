{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Parallax provider registry",
  "type": "object",
  "additionalProperties": true,
  "required": ["providers"],
  "properties": {
    "host_provider": {"type": "string", "enum": ["claude-code", "codex", "shell"]},
    "fallback_policy": {"type": "string", "minLength": 1},
    "probe_policy": {"type": "string", "enum": ["explicit"]},
    "provider_state_db": {"type": "string", "minLength": 1},
    "limits": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "warning_threshold_pct": {"type": "number", "minimum": 0, "maximum": 100},
        "handoff_threshold_pct": {"type": "number", "minimum": 0, "maximum": 100},
        "unknown_policy": {"type": "string", "enum": ["continue-with-warning", "park"]},
        "stale_ttl_s": {"type": "number", "minimum": 0},
        "max_sleep_s": {"type": "number", "minimum": 0},
        "reset_jitter_s": {"type": "number", "minimum": 0}
      }
    },
    "providers": {
      "type": "object", "minProperties": 1,
      "additionalProperties": {
        "type": "object", "additionalProperties": true,
        "required": ["kind", "transport"],
        "properties": {
          "kind": {"type": "string", "enum": ["worker", "reviewer", "both"]},
          "transport": {"type": "string", "minLength": 1},
          "command": {"type": "string", "minLength": 1},
          "model": {"type": ["string", "null"]},
          "key_env": {"type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"},
          "capabilities": {"type": "array", "items": {"type": "string"}},
          "base_url": {"type": "string"},
          "review_timeout_s": {"type": "number", "exclusiveMinimum": 0},
          "review_max_tokens": {"type": "integer", "minimum": 1},
          "review_thinking": {"type": "string", "enum": ["disabled", "enabled"]},
          "review_thinking_supported": {"type": "boolean"}
          ,"credential_class": {"type": "string"}
          ,"project_scope": {"type": "string"}
          ,"operator_budget_usd": {"type": "number", "minimum": 0}
          ,"operator_budget_scope": {"type": "string", "enum": ["estimate-only"]}
          ,"fallback_providers": {"type": "array", "items": {"type": "string"}}
          ,"credits_key_env": {"type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"}
          ,"logical_model": {"type": "string", "minLength": 1}
          ,"plan_name": {"type": ["string", "null"]}
          ,"limits_source_class": {"type": "string", "enum": ["official-api", "official-cli", "official-dashboard", "local-health-probe", "unknown"]}
          ,"limits_plan_source": {"type": "string", "enum": ["official-api", "official-cli", "official-dashboard", "local-health-probe", "unknown"]}
          ,"limits_limitations": {"type": "array", "items": {"type": "string"}}
          ,"probe_command": {"type": "string", "minLength": 1}
          ,"probe_read_only": {"type": "boolean"}
          ,"probe_timeout_s": {"type": "number", "exclusiveMinimum": 0}
          ,"auth_probe": {"type": "string", "enum": ["zai-models"]}
          ,"auth_endpoint": {"type": "string", "format": "uri"}
          ,"auth_method": {"type": "string", "enum": ["GET"]}
          ,"auth_timeout_s": {"type": "number", "exclusiveMinimum": 0}
          ,"live_signal_source_class": {"type": "string", "enum": ["official-api", "official-cli", "official-dashboard", "local-health-probe", "unknown"]}
          ,"budget_source_class": {"type": "string", "enum": ["official-api", "official-cli", "official-dashboard", "local-health-probe", "unknown"]}
          ,"budget_endpoint": {"type": "string", "format": "uri"}
          ,"budget_key_endpoint": {"type": "string", "format": "uri"}
          ,"credits_endpoint": {"type": "string", "format": "uri"}
          ,"models_endpoint": {"type": "string", "format": "uri"}
          ,"budget_method": {"type": "string"}
          ,"budget_exact": {"type": "boolean"}
          ,"routing": {
            "type": "object", "additionalProperties": false,
            "properties": {
              "only": {"type": "array", "items": {"type": "string"}},
              "order": {"type": "array", "items": {"type": "string"}},
              "allow_fallbacks": {"type": "boolean"},
              "models": {"type": "array", "items": {"type": "string"}},
              "data_retention_policy": {"type": "string"}
            }
          }
        }
      }
    },
    "roles": {"type": "object", "additionalProperties": {"type": "object", "required": ["chain"], "properties": {"chain": {"type": "array", "minItems": 1, "items": {"type": "string"}}, "required_capabilities": {"type": "array", "items": {"type": "string"}}, "automatic_fallback": {"type": "boolean"}}}}
  }
}
