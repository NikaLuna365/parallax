{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Parallax resolution receipt (one applied human decision batch)",
  "description": "Immutable receipt for one applied resolution batch at .parallax/<slug>/resolutions/<batch-id>.json. Written ONLY by scripts/resolution.py — never hand-authored. Binds the exact old/new contract hashes, the one-time confirmation token, and full invalidation. See DESIGN_v0.31_safe_completion.md §7.4.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "batch_id", "slug", "from_generation", "to_generation", "source_run_id", "new_run_id", "source_contract_hash", "new_contract_hash", "item_decisions", "exact_human_text", "confirmation_token", "contract_diff_hash", "invalidation_scope", "created_at", "status"],
  "properties": {
    "schema_version": { "const": 1 },
    "batch_id": { "type": "string", "pattern": "^RB-[0-9]+$" },
    "slug": { "type": "string", "minLength": 1 },
    "from_generation": { "type": "integer", "minimum": 1 },
    "to_generation": { "type": "integer", "minimum": 2, "description": "Must equal from_generation + 1 (enforced by resolution.py)." },
    "source_run_id": { "type": "string", "minLength": 1 },
    "new_run_id": { "type": "string", "minLength": 1 },
    "source_contract_hash": { "type": "string", "pattern": "^[0-9a-f]{7,64}$" },
    "new_contract_hash": { "type": "string", "pattern": "^[0-9a-f]{7,64}$", "description": "Must differ from source_contract_hash (an empty contract diff cannot create a generation)." },
    "item_decisions": {
      "type": "array",
      "minItems": 1,
      "description": "One decision per closed blocking item of this batch.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["item_id", "decision"],
        "properties": {
          "item_id": { "type": "string", "pattern": "^R-[A-Za-z0-9]+-[0-9]+$" },
          "decision": { "enum": ["choose-option", "custom-rule", "rescope", "abandon"], "description": "No 'ignore' / 'ship-anyway' / manual 'fixed' is admissible." },
          "option_id": { "type": ["string", "null"] },
          "rule": { "type": ["string", "null"], "description": "The concrete chosen/custom behavioral rule written into the new contract." }
        }
      }
    },
    "exact_human_text": { "type": "string", "minLength": 1, "description": "Audit evidence of the human's words — NOT proof of identity." },
    "confirmation_token": { "type": "string", "pattern": "^PARALLAX-RESOLVE:.+:g[1-9][0-9]*->g[1-9][0-9]*:RB-[0-9]+:[0-9a-f]+:[0-9a-f]+$" },
    "contract_diff_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "invalidation_scope": { "const": "all-slices", "description": "v0.31 always fully re-builds; partial impact analysis is deferred." },
    "created_at": { "type": "string", "minLength": 1 },
    "status": { "enum": ["applied"] }
  }
}
