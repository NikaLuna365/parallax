{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Parallax provider planning and frozen provider contract",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "host_provider", "roles", "providers", "fallback_policy"],
  "properties": {
    "schema_version": {"type": "string", "enum": ["parallax-provider-plan-v1", "parallax-provider-contract-v1"]},
    "host_provider": {"type": "string", "enum": ["claude-code", "codex", "shell"]},
    "roles": {"type": "object", "minProperties": 1, "additionalProperties": {"type": "object", "required": ["chain", "required_capabilities", "automatic_fallback"], "properties": {"chain": {"type": "array", "minItems": 1, "items": {"type": "string"}}, "required_capabilities": {"type": "array", "items": {"type": "string"}}, "automatic_fallback": {"type": "boolean"}}}},
    "providers": {"type": "array", "items": {"type": "object", "required": ["provider", "transport"], "properties": {"provider": {"type": "string"}, "transport": {"type": "string"}, "model": {"type": ["string", "null"]}, "kind": {"type": "string"}, "capabilities": {"type": "array", "items": {"type": "string"}}}}},
    "fallback_policy": {"type": "string", "minLength": 1},
    "budget_observations": {"type": "array"},
    "limitations": {"type": "array", "items": {"type": "string"}}
  }
}
