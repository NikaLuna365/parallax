# Cross-model verifier config for the Parallax pipeline.
# Copy to your repo as `.parallax/codex.toml` and edit. If this file is absent or
# `enabled = false`, the pipeline runs exactly as before (Claude-only gates),
# so the verifier is strictly additive and opt-in.
#
# TOML note: every bare key below MUST sit ABOVE the first [table] header, or TOML
# assigns it to that table. So: root scalars first, then the tables.

enabled    = true

# Which insertion points are active. Either or both:
#   "pre_freeze" — adversarial review of the frozen-candidate spec, before the blind tracks.
#   "post_green" — adversarial spec-gap + anti-cheat pass after a slice goes green.
points     = ["pre_freeze", "post_green"]

# Judge architecture:
#   "split" = (iii) Claude stays the in-loop arbiter; the verifier checks at the points above. (default)
#   "panel" = (ii)  Claude AND the verifier both judge post-green; a slice is green only if both pass.
#   "sole"  = (i)   the verifier replaces the Claude arbiter as the judge.
mode       = "split"

# What to do when EVERY provider in the chain is unavailable / errors (not just the primary):
#   interactive mode always falls back to the human gate (with a warning).
#   autonomous mode honors this:
#     "refuse" — do not run autonomously without a working verifier (recommended).
#     "warn"   — run, but stamp every output "UNVERIFIED — human review required".
on_missing = "refuse"

# Hard timeout per verifier invocation (seconds).
timeout_s  = 600


# Git branch namespace for everything the pipeline creates/pushes — the feature branch,
# the track branches, the lock, and the epic it integrates into. Default "feature/".
# For Claude Code *web (cloud) routines* — which run with the laptop OFF but allow pushes
# only to claude/* — set "claude/" so the whole run stays inside the allowed namespace
# (no need to loosen branch protection). Secrets are NEVER here; they come from env vars.
[git]
branch_prefix = "feature/"


# === Verifier provider chain ===
# The judge always runs a model that is NOT Claude — that independence is the whole
# point. Fallbacks are tried in order when the previous provider is rate-limited or
# unavailable, so a Codex limit falls back to Gemini instead of pausing the run; the
# run pauses ONLY if every provider is exhausted. Each provider, whatever its form,
# must return a verdict matching assets/codex/verdict.schema.json.

[primary]
provider = "codex"     # model family: codex | gemini | zai
form     = "cli"       # cli | api
model    = "gpt-5.5"   # confirm vs your installed `codex` (/model). Not a *-mini — the judge wants the strongest reasoning.
# codex CLI enforces the schema natively (codex exec --output-schema).

# === Fallback: z.ai (GLM) — an OpenAI-compatible HTTP API (v0.37.4) ===
# When codex is unavailable or rate-limited, the judge falls back to GLM here. No CLI
# needed — it's plain HTTP, so it works anywhere curl does (incl. cloud routines).
[fallback]
provider = "zai"        # model family: codex | gemini | zai
form     = "api"        # z.ai is HTTP-only (no CLI)
model    = "glm-5.2"    # confirmed live 2026-07-07 against api.z.ai; a REASONING model — budget generous max_tokens
base_url = "https://api.z.ai/api/paas/v4/chat/completions"   # OpenAI-compatible chat/completions
key_env  = "ZAI_API_KEY"   # NAME of the env var holding the key. The secret itself is NEVER in this committed file.
# Put the real key in an UNTRACKED, gitignored file and source it before the run, e.g.:
#     .parallax/zai.env   ->   export ZAI_API_KEY="…"        (already gitignored by the plugin)
#     $ source .parallax/zai.env    # before /parallax:run or the autonomous routine
# API form (see skills/role-codex-judge): the judge curls base_url with
#   Authorization: Bearer $ZAI_API_KEY  and  response_format={"type":"json_object"}
# (or a json_schema via scripts/strip-openai-schema.py), then validates the returned JSON
# against the FULL schema itself — exactly like the gemini-api path. GLM's chain-of-thought
# lands in message.reasoning_content; the verdict JSON is message.content.
#
# Alternative fallback — Gemini CLI:  provider="gemini" form="cli" model="gemini-3-pro"
#   (embed verdict.schema.json in the prompt; validate the returned JSON yourself).
#   For the Gemini API instead: form="api" key_env="GEMINI_API_KEY".


# Resume/retry policy for limit-pauses (applies to BOTH Claude and Codex limits).
# On a sustained limit the run checkpoints and pauses; an external scheduler
# (cron / CI / Cowork) re-fires `--resume` on this cadence until the run completes.
[retry]
interval_minutes      = 60   # hourly resume attempts (or honor the error's retry_after)
in_process_budget_min = 5    # short in-process retries for a blip before pausing the run


# Telegram notifications for the AUTONOMOUS flow (off by default; send-only).
# Secrets live in ENV VARS named here — NEVER put the bot token in this committed file.
[notify]
enabled     = false
channel     = "telegram"
mode        = "lifecycle"          # "lifecycle" = start / limit-pause / resume / complete / needs-human only
                                   # "verbose"   = the above PLUS every phase (slice dispatched/green/verified/integrated, wave done, ...)
token_env   = "PARALLAX_TG_BOT_TOKEN"   # name of the env var holding the bot token (the secret itself stays in the env)
chat_id_env = "PARALLAX_TG_CHAT_ID"     # name of the env var holding the chat id


# === Review memory & disposition (anti-oscillation + termination) ===
# Each review is a FRESH verifier invocation (we do NOT use `codex exec resume`): a persistent
# session makes the judge anchor on confirming its own past findings, the non-interactive session
# id is fragile to capture, and it would not survive a cloud fresh-clone anyway. Memory instead
# lives in PER-SLICE ledgers committed to the branch: .parallax/<slug>/reviews/<slice_id>.json
# (schema: assets/codex/review-ledger.schema.json). The verifier emits a review-round
# (assets/codex/review-round.schema.json); scripts/merge-ledger.py merges it mechanically and
# scripts/triage.py disposes — reading THIS policy from this trusted file, never from the ledger.
[review]
pre_freeze_max_rounds = 2     # max spec-adversary rounds before a mandatory human checkpoint; each explicit grant adds ONE round only
max_rounds           = 2     # max Codex review ROUNDS per slice (separate from the 3-iteration worker breaker); then PARK, don't loop
resume_codex_session = false # false = fresh verifier each round + external ledger (recommended). true would anchor; unsupported on cloud clones
recheck_fixed        = true  # a fresh review first re-checks prior open+fixed findings for regression before scanning for new ones
# Severity gating (the MECHANICAL half — see scripts/triage.py). A "low" finding is advisory:
# recorded + reported, but it does NOT block green. medium/high block. Claude may CONTEST a
# blocking finding only via a formal, ledgered reason (duplicate | not-reproducible |
# contradicts-spec | out-of-scope) — a contested medium/high ESCALATES (human decides); it is
# never silently dropped and never auto-greened.
block_severities     = ["medium", "high"]
advisory_severities  = ["low"]
# These ALWAYS block regardless of severity and can NOT be waived by a Claude rebuttal; a
# reproducible functional error (finding.functional_repro = true) always blocks too.
always_block_kinds   = ["safety", "anti-cheat", "spec-gap"]
